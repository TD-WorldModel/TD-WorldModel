source "https://rubygems.org"

# Jekyll 4 for local preview (works on modern Ruby).
# GitHub Pages builds the site remotely with its own Jekyll, so you don't
# need to match versions exactly for a simple static project page.
gem "jekyll", "~> 4.3"

# Ruby 3.0+ no longer ships webrick, which `jekyll serve` needs.
gem "webrick", "~> 1.8"

# Generates sitemap.xml (also on GitHub Pages' plugin allow-list).
gem "jekyll-sitemap", "~> 1.4"
